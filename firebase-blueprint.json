{
  "entities": {
    "Registration": {
      "title": "Registration",
      "description": "Student registration for a school",
      "type": "object",
      "properties": {
        "firstName": { "type": "string", "description": "Student's first name" },
        "lastName": { "type": "string", "description": "Student's last name" },
        "gradeLevel": { "type": "string", "description": "Grade level" },
        "phone": { "type": "string", "description": "Phone number" },
        "address": { "type": "string", "description": "Home address" },
        "chosenSchool": { "type": "string", "description": "Name of the primary chosen school" },
        "choice1": { "type": "string", "description": "First choice school (nearest)" },
        "choice2": { "type": "string", "description": "Second choice school" },
        "choice3": { "type": "string", "description": "Third choice school" },
        "isAccepted": { "type": "boolean", "description": "Whether the registration has been accepted by an admin" },
        "acceptedSchool": { "type": "string", "description": "The specific school the student was accepted into" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["firstName", "lastName", "gradeLevel", "phone", "address", "chosenSchool", "choice1", "choice2", "choice3", "createdAt"]
    },
    "SchoolStats": {
      "title": "SchoolStats",
      "description": "Statistics for a school",
      "type": "object",
      "properties": {
        "count": { "type": "integer", "description": "Number of registrations" },
        "schoolName": { "type": "string", "description": "Name of the school" }
      },
      "required": ["count", "schoolName"]
    }
  },
  "firestore": {
    "/registrations/{registrationId}": {
      "schema": "Registration",
      "description": "Collection of student registrations"
    },
    "/stats/{schoolId}": {
      "schema": "SchoolStats",
      "description": "Global statistics per school"
    }
  }
}
