rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Registration validation - using get() with default for robustness
    function isValidRegistration(data) {
      let firstName = data.get('firstName', '');
      let lastName = data.get('lastName', '');
      let gradeLevel = data.get('gradeLevel', '');
      let phone = data.get('phone', '');
      let address = data.get('address', '');
      let chosenSchool = data.get('chosenSchool', '');
      let choice1 = data.get('choice1', '');
      let choice2 = data.get('choice2', '');
      let choice3 = data.get('choice3', '');
      let isAccepted = data.get('isAccepted', false);
      let acceptedSchool = data.get('acceptedSchool', '');

      return firstName is string && firstName.size() <= 100
        && lastName is string && lastName.size() <= 100
        && gradeLevel is string && gradeLevel.size() <= 50
        && phone is string && phone.size() <= 20
        && address is string && address.size() <= 250
        && chosenSchool is string && chosenSchool.size() <= 100
        && choice1 is string && choice1.size() <= 100
        && choice2 is string && choice2.size() <= 100
        && choice3 is string && choice3.size() <= 100
        && isAccepted is bool
        && acceptedSchool is string && acceptedSchool.size() <= 100;
    }

    function isAdmin() {
      return isSignedIn() && 
             (request.auth.token.email == 'rrachidv4@gmail.com' || 
              (request.auth.token.email_verified == true && exists(/databases/$(database)/documents/admins/$(request.auth.uid))));
    }

    function isAdminEmail() {
      return isSignedIn() && request.auth.token.email == 'rrachidv4@gmail.com';
    }

    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && request.auth.token.email == 'rrachidv4@gmail.com');
    }

    match /registrations/{registrationId} {
      allow create: if isValidId(registrationId) && 
                      incoming().keys().hasAll(['firstName', 'lastName', 'gradeLevel', 'phone', 'address', 'chosenSchool', 'choice1', 'choice2', 'choice3', 'createdAt']) &&
                      incoming().keys().size() == 10 &&
                      isValidRegistration(incoming()) &&
                      incoming().createdAt == request.time;
      
      allow list, get: if true;
      
      allow update: if isValidId(registrationId) &&
                      incoming().updatedAt == request.time &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['firstName', 'lastName', 'gradeLevel', 'phone', 'address', 'chosenSchool', 'choice1', 'choice2', 'choice3', 'updatedAt', 'deletedAt', 'isAccepted', 'acceptedSchool']);
      
      allow delete: if isValidId(registrationId);
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    match /stats/{schoolId} {
      allow read: if isSignedIn();
      allow write: if isAdmin(); 
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
