rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Registration validation
    function isValidRegistration(data) {
      return data.keys().hasAll(['firstName', 'lastName', 'gradeLevel', 'phone', 'address', 'chosenSchool', 'createdAt'])
        && data.keys().size() == 7
        && data.firstName is string && data.firstName.size() <= 100
        && data.lastName is string && data.lastName.size() <= 100
        && data.gradeLevel is string && data.gradeLevel.size() <= 50
        && data.phone is string && data.phone.size() <= 20
        && data.address is string && data.address.size() <= 250
        && data.chosenSchool is string && data.chosenSchool.size() <= 100
        && data.createdAt == request.time;
    }

    function isAdmin() {
      return isSignedIn() && 
             (request.auth.token.email == 'rrachidv4@gmail.com' || 
              (request.auth.token.email_verified == true && exists(/databases/$(database)/documents/admins/$(request.auth.uid))));
    }

    match /registrations/{registrationId} {
      allow create: if isValidRegistration(request.resource.data);
      allow list, get, update, delete: if isAdmin();
    }

    match /stats/{schoolId} {
      allow read: if isSignedIn();
      allow write: if isAdmin(); 
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
