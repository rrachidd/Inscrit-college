rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Registration validation
    function isValidRegistration(data) {
      return data.firstName is string && data.firstName.size() <= 100
        && data.lastName is string && data.lastName.size() <= 100
        && data.gradeLevel is string && data.gradeLevel.size() <= 50
        && data.phone is string && data.phone.size() <= 20
        && data.address is string && data.address.size() <= 250
        && data.chosenSchool is string && data.chosenSchool.size() <= 100
        && data.choice1 is string && data.choice1.size() <= 100
        && data.choice2 is string && data.choice2.size() <= 100
        && data.choice3 is string && data.choice3.size() <= 100;
    }

    function isAdmin() {
      return isSignedIn() && 
             (request.auth.token.email == 'rrachidv4@gmail.com' || 
              (request.auth.token.email_verified == true && exists(/databases/$(database)/documents/admins/$(request.auth.uid))));
    }

    match /registrations/{registrationId} {
      allow create: if isValidId(registrationId) && 
                      incoming().keys().hasAll(['firstName', 'lastName', 'gradeLevel', 'phone', 'address', 'chosenSchool', 'choice1', 'choice2', 'choice3', 'createdAt']) &&
                      incoming().keys().size() == 10 &&
                      isValidRegistration(incoming()) &&
                      incoming().createdAt == request.time;
      
      allow list, get: if true;
      
      allow update: if (isAdmin() || isAdminEmail()) &&
                      isValidId(registrationId) &&
                      isValidRegistration(incoming()) &&
                      incoming().updatedAt == request.time &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['firstName', 'lastName', 'gradeLevel', 'phone', 'address', 'chosenSchool', 'choice1', 'choice2', 'choice3', 'updatedAt', 'deletedAt']);
      
      allow delete: if (isAdmin() || isAdminEmail()) && isValidId(registrationId);
    }

    function isAdminEmail() {
      return isSignedIn() && request.auth.token.email == 'rrachidv4@gmail.com';
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    match /stats/{schoolId} {
      allow read: if isSignedIn();
      allow write: if isAdmin(); 
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
