rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Registration validation
    function isValidRegistration(data) {
      return data.keys().hasAll(['firstName', 'lastName', 'gradeLevel', 'phone', 'address', 'chosenSchool', 'authorId', 'authorEmail', 'createdAt'])
        && data.keys().size() == 9
        && data.firstName is string && data.firstName.size() <= 100
        && data.lastName is string && data.lastName.size() <= 100
        && data.gradeLevel is string && data.gradeLevel.size() <= 50
        && data.phone is string && data.phone.size() <= 20
        && data.address is string && data.address.size() <= 250
        && data.chosenSchool is string && data.chosenSchool.size() <= 100
        && data.authorId == request.auth.uid
        && data.authorEmail is string
        && data.createdAt == request.time;
    }

    match /registrations/{registrationId} {
      allow create: if isSignedIn() && isValidRegistration(request.resource.data);
      allow read: if isSignedIn() && (resource.data.authorId == request.auth.uid || true); // Allow reading for stats in this demo
    }

    match /stats/{schoolId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); // In a real app, this would be highly restricted or handled by functions
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
